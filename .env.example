# OGI Environment Configuration
# Copy this file to .env and fill in values as needed.

# --- Supabase (hosted deployment) ---
# OGI_SUPABASE_URL=https://your-project.supabase.co
# OGI_SUPABASE_ANON_KEY=eyJ...
# OGI_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# OGI_SUPABASE_JWT_SECRET=your-jwt-secret

# --- Direct PostgreSQL (self-hosted via docker-compose) ---
OGI_DATABASE_URL=postgresql://postgres:postgres@db:5432/ogi

# --- SQLite fallback (local dev without PostgreSQL) ---
# OGI_USE_SQLITE=true
# OGI_DATABASE_PATH=ogi.db

# --- Plugin directories (comma-separated) ---
OGI_PLUGIN_DIRS=["plugins", "../plugins"]

# --- CORS origins ---
OGI_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Server ---
OGI_HOST=0.0.0.0
OGI_PORT=8000

# --- Frontend ---
OGI_FRONTEND_PORT=5173

# --- GitHub ---
OGI_GITHUB_TOKEN=github_pat_1...

# --- Security ---
# Comma-separated admin emails allowed to install/update/remove transforms
OGI_ADMIN_EMAILS=admin@example.com
# 32-byte urlsafe base64 key used by Fernet for API key encryption
OGI_API_KEY_ENCRYPTION_KEY=replace-with-fernet-key
